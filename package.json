{
  "name": "resume-match-engine",
  "version": "1.0.0",
  "description": "Resume Parsing & Job-Matching Index Engine — NestJS CLI over a reusable domain core",
  "license": "UNLICENSED",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "cli": "node dist/main.js",
    "pretest": "npm run build",
    "test": "jest",
    "test:live": "jest test/integration --testPathIgnorePatterns=/node_modules/ --testTimeout=60000",
    "test:cov": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nest-commander": "^3.16.0",
    "pdfjs-dist": "^6.1.200",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^9.1.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^29.7.0",
    "pdf-lib": "^1.17.1",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "tsc-alias": "^1.9.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.64.0"
  }
}
